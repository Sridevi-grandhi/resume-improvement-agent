# ============================================================
# Resume Improvement Agent — root .gitignore
# ============================================================

# ---------- Backend: Java / Maven ----------
backend/target/
*.class
*.war
*.ear
hs_err_pid*
replay_pid*

# ---------- Frontend: Node / Vite ----------
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Environment / secrets ----------
.env
.env.*
!.env.example

# ---------- IDE / editors ----------
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
*.swp
*.swo

# ---------- OS files ----------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ---------- Logs ----------
*.log
logs/
